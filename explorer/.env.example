# Server-side secret. Never commit a real key or paste one into the browser UI.
# Keep this exact name: NEXT_PUBLIC_ and VITE_ prefixes would expose it to the browser.
OPENAI_API_KEY=

# Optional override. The Build Week prototype defaults to GPT-5.6.
OPENAI_MODEL=gpt-5.6

# Public deployments fail closed until an account-side Cloudflare rate limit
# or equivalent protection is installed for POST /api/query, /api/adapt,
# /api/owl, and /api/translate. Leave false for local development.
AI_RATE_LIMIT_CONFIGURED=false
